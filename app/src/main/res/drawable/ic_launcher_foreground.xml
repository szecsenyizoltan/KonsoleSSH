<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground: orange "> _" prompt on a transparent background.
  The 72dp safe zone (X/Y 18..90) keeps the glyph visible under all launcher
  masks (circle, squircle, rounded-square, etc.).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- > chevron -->
    <path
        android:strokeColor="#E95420"
        android:strokeWidth="8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M 30,36 L 55,54 L 30,72" />

    <!-- _ underscore -->
    <path
        android:fillColor="#E95420"
        android:pathData="M 60,70 H 86 V 76 H 60 Z" />

</vector>
