<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/terminal_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/toolbar_bg"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/toolbar_bg"
            app:title=""
            app:titleTextColor="@color/text_primary" />

        <!-- Tab bar row: TabLayout + "+" button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/tab_bg">

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                app:tabMode="scrollable"
                app:tabGravity="start"
                app:tabBackground="@color/tab_bg"
                app:tabSelectedTextColor="@color/tab_selected_text"
                app:tabTextColor="@color/tab_unselected_text"
                app:tabIndicatorColor="@color/accent"
                app:tabIndicatorHeight="2dp"
                app:tabPaddingStart="0dp"
                app:tabPaddingEnd="0dp" />

            <ImageButton
                android:id="@+id/btnNewTab"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@android:drawable/ic_input_add"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/accent"
                android:contentDescription="@string/content_desc_new_tab"
                android:layout_gravity="center_vertical" />

            <ImageButton
                android:id="@+id/btnZoomOut"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="9dp"
                android:src="@drawable/ic_zoom_out"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#AAAAAA"
                android:contentDescription="@string/content_desc_zoom_out"
                android:layout_gravity="center_vertical" />

            <ImageButton
                android:id="@+id/btnZoomIn"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="9dp"
                android:src="@drawable/ic_zoom_in"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#AAAAAA"
                android:contentDescription="@string/content_desc_zoom_in"
                android:layout_gravity="center_vertical" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- F-key row -->
    <FrameLayout
        android:id="@+id/fnbarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone">

        <HorizontalScrollView
            android:id="@+id/fnbarScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/keybar_bg"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <Button android:id="@+id/btnF1"  style="@style/KeyBarButton" android:text="F1" />
                <Button android:id="@+id/btnF2"  style="@style/KeyBarButton" android:text="F2" />
                <Button android:id="@+id/btnF3"  style="@style/KeyBarButton" android:text="F3" />
                <Button android:id="@+id/btnF4"  style="@style/KeyBarButton" android:text="F4" />
                <Button android:id="@+id/btnF5"  style="@style/KeyBarButton" android:text="F5" />
                <Button android:id="@+id/btnF6"  style="@style/KeyBarButton" android:text="F6" />
                <Button android:id="@+id/btnF7"  style="@style/KeyBarButton" android:text="F7" />
                <Button android:id="@+id/btnF8"  style="@style/KeyBarButton" android:text="F8" />
                <Button android:id="@+id/btnF9"  style="@style/KeyBarButton" android:text="F9" />
                <Button android:id="@+id/btnF10" style="@style/KeyBarButton" android:text="F10" />
                <Button android:id="@+id/btnF11" style="@style/KeyBarButton" android:text="F11" />
                <Button android:id="@+id/btnF12" style="@style/KeyBarButton" android:text="F12" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/fnbarScrollHintLeft"
            android:layout_width="32dp"
            android:layout_height="36dp"
            android:layout_gravity="start|center_vertical"
            android:text="◀"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@color/keybar_bg"
            android:visibility="gone" />

        <TextView
            android:id="@+id/fnbarScrollHint"
            android:layout_width="32dp"
            android:layout_height="36dp"
            android:layout_gravity="end|center_vertical"
            android:text="▶"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@color/keybar_bg"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Ctrl+X combo row (shown while Ctrl is active) -->
    <FrameLayout
        android:id="@+id/ctrlbarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone">

        <HorizontalScrollView
            android:id="@+id/ctrlbarScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/keybar_bg"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/ctrlbarButtons"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/ctrlbarScrollHintLeft"
            android:layout_width="32dp"
            android:layout_height="36dp"
            android:layout_gravity="start|center_vertical"
            android:text="◀"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@color/keybar_bg"
            android:visibility="gone" />

        <TextView
            android:id="@+id/ctrlbarScrollHint"
            android:layout_width="32dp"
            android:layout_height="36dp"
            android:layout_gravity="end|center_vertical"
            android:text="▶"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@color/keybar_bg"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Arrow keys row (toggled with ↑ button in keybar) -->
    <FrameLayout
        android:id="@+id/arrowbarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone">

        <HorizontalScrollView
            android:id="@+id/arrowbarScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/keybar_bg"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnArrowLeft"
                    style="@style/KeyBarButton"
                    android:text="←" />

                <Button
                    android:id="@+id/btnArrowUp"
                    style="@style/KeyBarButton"
                    android:text="↑" />

                <Button
                    android:id="@+id/btnArrowDown"
                    style="@style/KeyBarButton"
                    android:text="↓" />

                <Button
                    android:id="@+id/btnArrowRight"
                    style="@style/KeyBarButton"
                    android:text="→" />

            </LinearLayout>
        </HorizontalScrollView>

    </FrameLayout>

    <!-- Extra key toolbar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <HorizontalScrollView
            android:id="@+id/keybarScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/keybar_bg"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnKeyboard"
                    style="@style/KeyBarButton"
                    android:text="⌨" />

                <Button
                    android:id="@+id/btnFn"
                    style="@style/KeyBarButton"
                    android:text="Fn" />

                <View style="@style/KeyBarDivider" />

                <Button
                    android:id="@+id/btnModCtrl"
                    style="@style/KeyBarButton"
                    android:text="CTRL" />

                <Button
                    android:id="@+id/btnModShift"
                    style="@style/KeyBarButton"
                    android:text="SHIFT" />

                <Button
                    android:id="@+id/btnModAlt"
                    style="@style/KeyBarButton"
                    android:text="ALT" />

                <Button
                    android:id="@+id/btnModAltGr"
                    style="@style/KeyBarButton"
                    android:text="ALTGR" />

                <View style="@style/KeyBarDivider" />

                <Button
                    android:id="@+id/btnEscape"
                    style="@style/KeyBarButton"
                    android:text="ESC" />

                <Button
                    android:id="@+id/btnTab"
                    style="@style/KeyBarButton"
                    android:text="TAB" />

                <View style="@style/KeyBarDivider" />

                <Button
                    android:id="@+id/btnArrowToggle"
                    style="@style/KeyBarButton"
                    android:text="↑" />

            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/keybarScrollHintLeft"
            android:layout_width="32dp"
            android:layout_height="40dp"
            android:layout_gravity="start|center_vertical"
            android:text="◀"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@color/keybar_bg"
            android:visibility="gone" />

        <TextView
            android:id="@+id/keybarScrollHint"
            android:layout_width="32dp"
            android:layout_height="40dp"
            android:layout_gravity="end|center_vertical"
            android:text="▶"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@color/keybar_bg"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
