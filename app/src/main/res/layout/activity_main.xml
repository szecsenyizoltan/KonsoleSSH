<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/toolbar_bg"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/toolbar_bg"
            app:title=""
            app:titleTextColor="@color/text_primary" />

        <!-- Tab bar row: TabLayout + "+" button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/tab_bg">

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                app:tabMode="scrollable"
                app:tabGravity="start"
                app:tabBackground="@color/tab_bg"
                app:tabSelectedTextColor="@color/tab_selected_text"
                app:tabTextColor="@color/tab_unselected_text"
                app:tabIndicatorColor="@color/accent"
                app:tabIndicatorHeight="2dp"
                app:tabPaddingStart="0dp"
                app:tabPaddingEnd="0dp" />

            <ImageButton
                android:id="@+id/btnNewTab"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@android:drawable/ic_input_add"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/accent"
                android:contentDescription="Új fül"
                android:layout_gravity="center_vertical" />

            <ImageButton
                android:id="@+id/btnZoomOut"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="9dp"
                android:src="@drawable/ic_zoom_out"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#AAAAAA"
                android:contentDescription="Kicsinyítés"
                android:layout_gravity="center_vertical" />

            <ImageButton
                android:id="@+id/btnZoomIn"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="9dp"
                android:src="@drawable/ic_zoom_in"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#AAAAAA"
                android:contentDescription="Nagyítás"
                android:layout_gravity="center_vertical" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

<androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
