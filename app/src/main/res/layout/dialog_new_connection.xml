<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Saved connections picker -->
        <LinearLayout
            android:id="@+id/savedConnectionsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/load_saved_connection"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerSaved"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/input_bg" />

        </LinearLayout>

        <!-- Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/connection_name_hint"
            style="@style/KonsoleInputLayout"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editName"
                style="@style/KonsoleInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionNext" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Internal host -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/host_hint"
            style="@style/KonsoleInputLayout"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editHost"
                style="@style/KonsoleInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:imeOptions="actionNext" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Internal port + Username row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutPort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/port_hint"
                style="@style/KonsoleInputLayout"
                android:layout_marginEnd="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editPort"
                    style="@style/KonsoleInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="@string/default_ssh_port"
                    android:imeOptions="actionNext" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:hint="@string/username_hint"
                style="@style/KonsoleInputLayout">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editUsername"
                    style="@style/KonsoleInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:imeOptions="actionNext" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Auth type -->
        <RadioGroup
            android:id="@+id/radioGroupAuth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <RadioButton
                android:id="@+id/radioPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/password"
                android:checked="true"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="16dp" />

            <RadioButton
                android:id="@+id/radioPrivateKey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/private_key"
                android:textColor="@color/text_primary" />

        </RadioGroup>

        <!-- Password section -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/password_hint_optional"
            style="@style/KonsoleInputLayout"
            app:passwordToggleEnabled="true"
            android:layout_marginBottom="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editPassword"
                style="@style/KonsoleInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Test connection row (only meaningful with a password) -->
        <LinearLayout
            android:id="@+id/layoutTestRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnTestConnection"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/action_test_connection"
                android:textSize="13sp"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:textColor="@color/accent"
                android:paddingStart="0dp" />

            <TextView
                android:id="@+id/textTestStatus"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="8dp"
                android:ellipsize="end"
                android:maxLines="2" />

        </LinearLayout>

        <!-- Private key section -->
        <LinearLayout
            android:id="@+id/layoutPrivateKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- File picker button -->
                <Button
                    android:id="@+id/btnPickKeyFile"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/pick_key_file"
                    android:textSize="13sp"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:textColor="@color/accent"
                    android:paddingStart="0dp" />

                <!-- Key generator button (enabled after successful connection test) -->
                <Button
                    android:id="@+id/btnGenerateKey"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/generate_and_upload_key"
                    android:textSize="13sp"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:textColor="@color/accent"
                    android:enabled="false"
                    android:layout_marginStart="4dp" />

                <TextView
                    android:id="@+id/textKeyStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sym_check"
                    android:textColor="@color/success_color"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:visibility="gone"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Hidden field to store the key content -->
            <EditText
                android:id="@+id/editPrivateKey"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Jump host toggle button (visible when NOT internal IP) -->
        <Button
            android:id="@+id/btnToggleJump"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/configure_jump_host"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:textColor="@color/accent"
            android:paddingStart="0dp"
            android:visibility="gone" />

        <!-- Jump host section (visible when internal IP detected OR toggled) -->
        <LinearLayout
            android:id="@+id/jumpSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="8dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/tab_unselected_text"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/jump_host_section_title"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/jump_host_pick_hint"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerJumpConnection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/input_bg"
                android:layout_marginBottom="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/tab_unselected_text"
                android:layout_marginBottom="10dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
