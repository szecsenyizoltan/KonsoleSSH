<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/terminal_bg">

    <!-- Status bar -->
    <TextView
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:textSize="11sp"
        android:textColor="@color/status_text"
        android:background="@color/status_bg"
        android:singleLine="true"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:fontFamily="monospace"
        android:text="@string/status_no_connection" />

    <!-- Terminal output -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <hu.billman.konsolessh.terminal.TerminalView
            android:id="@+id/terminalView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:id="@+id/btnReconnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:text="@string/sym_refresh"
                android:textSize="32sp"
                android:textColor="@color/accent"
                android:gravity="center"
                android:background="@drawable/bg_reconnect_btn" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/action_reconnect"
                android:textSize="13sp"
                android:textColor="@color/accent"
                android:fontFamily="monospace" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
