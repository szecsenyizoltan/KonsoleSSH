<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.KonsoleSSH" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/toolbar_bg</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/terminal_bg</item>
        <item name="android:windowBackground">@color/terminal_bg</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="android:statusBarColor">@color/toolbar_bg</item>
        <item name="android:navigationBarColor">@color/terminal_bg</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Dialog style -->
    <style name="KonsoleDialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:colorBackground">@color/card_bg</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
    </style>

    <!-- Input layout style -->
    <style name="KonsoleInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:editTextColor">@color/text_primary</item>
    </style>

    <!-- Edit text inside KonsoleInputLayout -->
    <style name="KonsoleInputEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Key toolbar button -->
    <style name="KeyBarButton" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/keybar_key_text</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:layout_marginStart">2dp</item>
        <item name="android:layout_marginEnd">2dp</item>
        <item name="android:background">@color/keybar_key_bg</item>
        <item name="android:focusable">false</item>
    </style>

    <!-- Divider in key bar -->
    <style name="KeyBarDivider">
        <item name="android:layout_width">1dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:background">@color/tab_unselected_text</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginEnd">4dp</item>
    </style>

</resources>
